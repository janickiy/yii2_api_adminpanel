APP_NAME="Yii2 API Adminpanel"
APP_ENV=dev
APP_DEBUG=true
APP_URL=http://localhost:8082
APP_PORT=8082

COOKIE_VALIDATION_KEY=yii2_api_adminpanel_cookie_key_change_me

DB_HOST=mysql_db
DB_PORT=3306
DB_DATABASE=yii2_api_adminpanel_db
DB_USERNAME=root
DB_PASSWORD=root_password

PG_DB_HOST=pg_db
PG_DB_PORT=5432
PG_DB_NAME=yii2_api_adminpanel_pg_db
PG_DB_USER=user_pg
PG_DB_PASSWORD=pass_pg

JWT_SECRET=yii2_api_adminpanel_dev_secret_change_me_32_chars_minimum_2026
JWT_TTL=3600

ADMIN_EMAIL=admin@example.com
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"
