APP_NAME="Notes Service"
APP_ENV=dev
APP_DEBUG=true
APP_URL=http://localhost:8082
APP_PORT=8082
APP_LANGUAGE=ru-RU
APP_TIMEZONE=Europe/Moscow

COOKIE_VALIDATION_KEY=replace-with-a-long-random-cookie-key

DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=notes
DB_USERNAME=notes
DB_PASSWORD=notes
DB_SCHEMA_CACHE=false

CACHE_DRIVER=memcached
CACHE_HOST=memcached
CACHE_PORT=11211
NOTES_CACHE_TTL=120

REDIS_HOST=redis
REDIS_PORT=6379

JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ISSUER=http://localhost:8082
JWT_AUDIENCE=notes-api
JWT_TTL=3600
JWT_LEEWAY=10
